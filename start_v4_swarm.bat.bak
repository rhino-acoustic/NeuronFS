@echo off
:: ?Җ?Җ?Җ SELF-ELEVATING STEALTH MODE ?Җ?Җ?Җ
if "%~1"=="-stealth" goto :stealth_main

echo [NeuronFS] Switching to stealth background mode...
set "VBS_FILE=%TEMP%\run_stealth.vbs"
echo Set WshShell = CreateObject("WScript.Shell") > "%VBS_FILE%"
echo WshShell.Run """" ^& WScript.Arguments(0) ^& """" ^& " -stealth", 0, False >> "%VBS_FILE%"
wscript "%VBS_FILE%" "%~dpnx0"
del "%VBS_FILE%"
exit /b

:stealth_main
title CDP Auto Accept + NeuronFS Brain v2.0
chcp 65001 >nul
color 0A

:: ?Җ?Җ?Җ AUTO-STOP: кё°мЎҙ л°ұк·ё?јмҡҙ???”м—¬ ?°лӘ¬ к№”лҒ”?ҳкІҢ ?ҷмӮҙ ?Җ?Җ?Җ
taskkill /F /IM neuronfs.exe /T >nul 2>&1
taskkill /F /FI "WINDOWTITLE eq NeuronFS*" /T >nul 2>&1
taskkill /F /IM node.exe /FI "COMM eq node.exe *hijack*" >nul 2>&1

:: UTF-8 к°•м ң ??PowerShell/Node ?ҳмң„ ?„лЎң?ёмҠӨ ?„л? ?Ғмҡ©
set "PYTHONIOENCODING=utf-8"
set "LANG=en_US.UTF-8"
powershell -NoProfile -Command "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; $OutputEncoding = [System.Text.Encoding]::UTF8" >nul 2>&1

:: NODE_OPTIONS л°ұмҠ¬?ҳмӢң кІҪлЎң к№Ём§җ л°©м? (Node.js v24+)
:: DISABLED: v4-hook patches http2 inside Antigravity, breaks chat persistence
:: set "NODE_OPTIONS=--require C:/Users/BASEMENT_ADMIN/NeuronFS/runtime/v4-hook.cjs"
echo ==============================================
echo    V4 Headless Hook + NeuronFS Brain Engine
echo    All-in-One Swarm Launcher v2.0
echo ==============================================
echo.

cd /d "%~dp0"

set "ANTIGRAVITY=%LOCALAPPDATA%\Programs\Antigravity\Antigravity.exe"
set CDP_PORT=9000
set "NEURONFS_DIR=C:\Users\BASEMENT_ADMIN\NeuronFS"
set "NEURONFS_EXE=%NEURONFS_DIR%\neuronfs.exe"
set "RUNTIME_DIR=%NEURONFS_DIR%\runtime"
set "BRAIN_PATH=%NEURONFS_DIR%\brain_v4"
set "NAS_BRAIN=Z:\VOL1\VGVR\BRAIN\LW\system\neurons\brain_v4"
set "BRIDGE_SCRIPT=%RUNTIME_DIR%\agent-bridge.mjs"
set "WATCHDOG_SCRIPT=%NEURONFS_DIR%\watchdog.ps1"
set "BOT1_DIR=C:\Users\BASEMENT_ADMIN\bot1"
set "ENTP_DIR=C:\Users\BASEMENT_ADMIN\entp"
set "ENFP_DIR=C:\Users\BASEMENT_ADMIN\enfp"

:: --- мўҖл№??„лЎң?ёмҠӨ ?•лҰ¬ ---
echo [INFO] ?җл””???•мғҒ мў…лЈҢ ?ңлҸ„ (?ём…ҳ ?Җ???Җкё?...
taskkill /IM "Antigravity.exe" >nul 2>&1
set AG_WAIT=0
:AG_WAIT_LOOP
tasklist /FI "IMAGENAME eq Antigravity.exe" 2>nul | find /I "Antigravity.exe" >nul
if %errorlevel% neq 0 (
    echo [OK] Antigravity ?•мғҒ мў…лЈҢ ?„лЈҢ
    goto AG_DONE
)
if %AG_WAIT% geq 30 (
    echo [WARN] 30мҙ?мҙҲкіј - к°•м ң мў…лЈҢ
    taskkill /F /IM "Antigravity.exe" >nul 2>&1
    goto AG_DONE
)
set /a AG_WAIT+=2
timeout /t 2 /nobreak >nul
goto AG_WAIT_LOOP
:AG_DONE
taskkill /F /IM "neuronfs.exe" >nul 2>&1
:: Zombie Hunt (kill processes matching old hijackers)
powershell -NoProfile -Command "Get-CimInstance Win32_Process | Where-Object { $_.CommandLine -match 'v4-hook\\.cjs|context-hijacker\\.mjs|headless-executor\\.mjs|hijack-launcher\\.mjs' } | Invoke-CimMethod -MethodName Terminate" >nul 2>&1
echo [OK] Zombie hijackers cleared

:: --- Node.js мўҖл№??•лҰ¬ ---
taskkill /F /IM "node.exe" >nul 2>&1
echo [OK] Node.js zombies cleared

:: --- лЎңк·ё лЎңн…Ң?ҙм…ҳ (100MB мҙҲкіј ?? ң) ---
for %%F in ("%NEURONFS_DIR%\logs\*.log") do (
    if %%~zF GTR 104857600 (
        del /q "%%F" >nul 2>&1
        echo [OK] Rotated: %%~nxF
    )
)

if "%GROQ_API_KEY%"=="" (
    echo [WARN] GROQ_API_KEY not set. Run: setx GROQ_API_KEY "your_key_here"
    echo.
) else (
    echo [OK] GROQ_API_KEY detected
)

where node >nul 2>nul
if %errorlevel% neq 0 (
    echo [ERROR] Node.js not installed.
    pause
    exit /b 1
)

if not exist "node_modules\ws" (
    echo [INFO] Installing ws...
    call npm install ws >nul 2>&1
)

:: л¬ҙмЎ°кұ??ҲлЎң л№Ңл“ң?ҳкё° ?„н•ҙ кё°мЎҙ ?Ңмқј ?? ң
if exist "%NEURONFS_EXE%" del /q "%NEURONFS_EXE%"

:BUILD_NFS
echo [INFO] Building neuronfs.exe...
where go >nul 2>nul
if %errorlevel% neq 0 (
    echo [ERROR] Go not installed.
    pause
    exit /b 1
)
pushd "%RUNTIME_DIR%"
go build -o "%NEURONFS_EXE%" .
popd

:NFS_READY
echo [OK] neuronfs.exe ready

powershell -Command "try{$null=Invoke-WebRequest -Uri 'http://127.0.0.1:%CDP_PORT%/json/list' -UseBasicParsing -TimeoutSec 2;exit 0}catch{exit 1}" >nul 2>&1
if %errorlevel% equ 0 (
    echo [OK] CDP already active
    goto OPEN_BOTS
)

echo [INFO] Launching V4 Headless Executor (Background Daemon)...
start /B "" node "C:\Users\BASEMENT_ADMIN\_architecture_hijack_v4\headless-executor.mjs"

echo [3/6] Starting Network Sniffers (Hijackers)...
:: кө¬нҳ• м»Ён…Қ?ӨнҠё ?ҳмқҙ?¬м»Ө (MITM 8080) - Anthropic / Google ?ёмҰқ???ЁнӮ· ?Ҳм·Ё??
start /B "" node "%RUNTIME_DIR%\hijackers\context-hijacker.mjs"

:: ?өн•© ?ҳмқҙ???°мІҳ (H2 Patch + CDP Auto-Attach + Swarm Extraction 10-chunk)
start /B "" node "%RUNTIME_DIR%\hijackers\hijack-launcher.mjs"

set "NEURONFS_BRAIN=%BRAIN_PATH%"

:: ?Җ?Җ?Җ CRITICAL: Antigravity ?ём…ҳ ?Җ??л¬ҙкІ°??ліҙнҳё ?Җ?Җ?Җ
:: NODE_OPTIONS (v4-hook.cjs), PROXY, TLS ?Өм •??Antigravity???ҒмҶҚ?ҳл©ҙ
:: IDE ?ҙл? gRPC/HTTPS ?ӨнҠёлҰјмқҙ ?Өм—ј?ҳм–ҙ ?ём…ҳ(?Җ?? ?Җ?Ҙмқҙ ?ӨнҢЁ??
:: ??IDE?җлҠ” ?ҙлҰ° ?ҳкІҪ???ңкіө?ҳкі , ?ҳмқҙ?¬м»Ө???ҙл? лі„лҸ„ ?„лЎң?ёмҠӨлЎ??ҷмһ‘ мӨ?
set "_SAVED_NODE_OPTIONS=%NODE_OPTIONS%"
set "NODE_OPTIONS="
set "HTTPS_PROXY="
set "HTTP_PROXY="
set "NODE_TLS_REJECT_UNAUTHORIZED="

echo [INFO] Launching Antigravity (CLEAN env - no hook/proxy for session safety)...
start "" "%ANTIGRAVITY%" --remote-debugging-port=%CDP_PORT%

:: Antigravity ?ңмһ‘ ???ҳкІҪліҖ??ліөмӣҗ (?ӨлҘё ?ёл“ң ?„лЎң?ёмҠӨ??
set "NODE_OPTIONS=%_SAVED_NODE_OPTIONS%"
set "HTTPS_PROXY=http://127.0.0.1:8080"
set "HTTP_PROXY=http://127.0.0.1:8080"
set "NODE_TLS_REJECT_UNAUTHORIZED=0"

set RETRIES=0
:WAIT_LOOP
timeout /t 2 /nobreak >nul
set /a RETRIES+=1
powershell -Command "try{$null=Invoke-WebRequest -Uri 'http://127.0.0.1:%CDP_PORT%/json/list' -UseBasicParsing -TimeoutSec 2;exit 0}catch{exit 1}" >nul 2>&1
if %errorlevel% equ 0 (
    echo [OK] CDP connected
    goto OPEN_BOTS
)
if %RETRIES% gtr 30 (
    echo [ERROR] CDP timeout
    pause
    exit /b 1
)
echo [INFO] Waiting... (%RETRIES%/30)
goto WAIT_LOOP

:OPEN_BOTS
echo.
echo [INFO] Skipping auto-open of bot workspaces (Manual mode)
:: if exist "%BOT1_DIR%" start "" "%ANTIGRAVITY%" "%BOT1_DIR%"
:: timeout /t 2 /nobreak >nul
:: if exist "%ENTP_DIR%" start "" "%ANTIGRAVITY%" "%ENTP_DIR%"
:: timeout /t 2 /nobreak >nul
:: if exist "%ENFP_DIR%" start "" "%ANTIGRAVITY%" "%ENFP_DIR%"
echo [OK] Bot workspaces skipped

echo.
echo.
echo [INFO] Starting NeuronFS Supervisor...
echo.

:: supervisorеӘӣвӮ¬ п§Ҹв‘Өлұ??кҫЁмӨҲ?лӘ„л’Ә???ҝвӮ¬??
::   neuronfs --api, --watch, agent-bridge, auto-accept, bot-heartbeat, NAS sync, harness
start /B "" "%NEURONFS_EXE%" "%BRAIN_PATH%" --supervisor
echo [OK] Supervisor started (manages all child processes)

echo.
echo ==============================================
echo    ALL SYSTEMS GO
echo ==============================================
echo   CDP:       http://127.0.0.1:%CDP_PORT%
echo   Dashboard: http://localhost:9090 (via supervisor)
echo   Bots:      bot1 + entp + enfp
echo   Supervisor: process auto-restart + harness
echo   Heartbeat:  PM controlled (heartbeat.lock)
echo   Ctrl+C to stop
echo ==============================================
echo.

:: [SKIPPED] Wait for connections
:: echo [INFO] Waiting 30s for bot connections...
:: timeout /t 30 /nobreak >nul

:: [SKIPPED] Kickstart all agents with autonomous evolution
:: echo [INFO] Injecting baseline personas...
:: node "%RUNTIME_DIR%\core_agents\kickstart.mjs" all

echo.
echo ==============================================
echo    ALL AUTONOMOUS - ZERO IDLE
echo ==============================================
echo   Supervisor:  1 process manages all services
echo   Heartbeat:   PM tool (lock on/off)
echo   All services continue in background
echo ==============================================
pause

